meta {
  name: Get Waste Movement By Waste Tracking ID
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/qa-non-prod/movements?wasteTrackingId=26ALK418
  body: none
  auth: basic
}

params:query {
  wasteTrackingId: 26ALK418
}

headers {
  x-api-key: {{cdp-api-key}}
  x-cdp-request-id: {{$randomUUID}}
  Accept-Encoding: identity
}

auth:basic {
  username: qa-non-prod
  password: {{AUTH_PASSWORD_QA_NON_PROD}}
}

settings {
  encodeUrl: true
  timeout: 0
}
